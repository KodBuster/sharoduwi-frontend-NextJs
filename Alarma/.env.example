# Скопируйте этот файл в .env.local и вставьте свои ключи.
# Сгенерировать:  npm run vapid   (или  node scripts/generate-vapid.mjs)

# Публичный VAPID-ключ — попадает на клиент (префикс NEXT_PUBLIC_).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Приватный VAPID-ключ — ТОЛЬКО сервер, держать в секрете!
VAPID_PRIVATE_KEY=

# Контакт администратора (email или URL сайта).
VAPID_SUBJECT=mailto:admin@sharoduwi.ru
